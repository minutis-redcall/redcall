{
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.4",
    "ext-dom": "*",
    "ext-gd": "*",
    "ext-iconv": "*",
    "ext-intl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "babdev/pagerfanta-bundle": "^4.4",
    "composer/package-versions-deprecated": "1.11.99.5",
    "craue/formflow-bundle": "3.99.99",
    "doctrine/doctrine-bundle": "^3.2",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "doctrine/orm": "^3.0",
    "exercise/htmlpurifier-bundle": "^5.0",
    "facile-it/doctrine-mysql-come-back": "^3.0",
    "firebase/php-jwt": "^7.0",
    "giggsey/libphonenumber-for-php": "^9.0",
    "google/apiclient": "^2.19",
    "google/cloud-error-reporting": "^0.26",
    "google/cloud-storage": "^2.0",
    "google/cloud-tasks": "^2.0",
    "google/cloud-text-to-speech": "^2.0",
    "google/recaptcha": "^1.3",
    "guzzlehttp/guzzle": "^7.4.5",
    "league/commonmark": "^2.8.1",
    "league/csv": "^9.1",
    "mpdf/mpdf": "^8.0",
    "myclabs/php-enum": "^1.7",
    "pagerfanta/doctrine-orm-adapter": "^4.4",
    "pagerfanta/twig": "^4.8",
    "phpdocumentor/reflection-docblock": "^6.0",
    "ramsey/uuid": "^4.0",
    "sendgrid/sendgrid": "^8.0",
    "symfony/apache-pack": "^1.0",
    "symfony/asset": "^8.0",
    "symfony/browser-kit": "^8.0",
    "symfony/console": "^8.0",
    "symfony/dotenv": "^8.0",
    "symfony/expression-language": "^8.0",
    "symfony/flex": "^2.4",
    "symfony/form": "^8.0",
    "symfony/framework-bundle": "^8.0",
    "symfony/http-client": "^8.0",
    "symfony/mailer": "^8.0",
    "symfony/monolog-bundle": "^4.0",
    "symfony/process": "^8.0",
    "symfony/property-access": "^8.0",
    "symfony/property-info": "^8.0",
    "symfony/runtime": "^8.0",
    "symfony/security-bundle": "^8.0",
    "symfony/security-csrf": "^8.0",
    "symfony/serializer": "^8.0",
    "symfony/translation": "^8.0",
    "symfony/twig-bridge": "^8.0",
    "symfony/twig-bundle": "^8.0",
    "symfony/validator": "^8.0",
    "symfony/web-link": "^8.0",
    "symfony/webpack-encore-bundle": "^2.0",
    "symfony/yaml": "^8.0",
    "twig/extra-bundle": "^3.3",
    "twig/intl-extra": "^3.0",
    "twig/markdown-extra": "^3.3",
    "twig/string-extra": "^3.3",
    "twilio/sdk": "^8.0"
  },
  "require-dev": {
    "dama/doctrine-test-bundle": "^8.0",
    "phpunit/phpunit": "^13.0",
    "rector/rector": "^2.4",
    "symfony/css-selector": "^8.0",
    "symfony/debug-bundle": "^8.0",
    "symfony/maker-bundle": "^1.0",
    "symfony/phpunit-bridge": "^8.0",
    "symfony/stopwatch": "^8.0",
    "symfony/web-profiler-bundle": "^8.0"
  },
  "repositories": [
    {
      "type": "path",
      "url": "bundles/formflow-bundle",
      "options": {
        "symlink": false
      }
    }
  ],
  "config": {
    "platform": {
      "php": "8.4.18"
    },
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Bundles\\GoogleTaskBundle\\": "bundles/google-task-bundle/",
      "Bundles\\PaginationBundle\\": "bundles/pagination-bundle/",
      "Bundles\\PasswordLoginBundle\\": "bundles/password-login-bundle/",
      "Bundles\\PegassCrawlerBundle\\": "bundles/pegass-crawler-bundle/",
      "Bundles\\SandboxBundle\\": "bundles/sandbox-bundle/",
      "Bundles\\SettingsBundle\\": "bundles/settings-bundle/",
      "Bundles\\TwilioBundle\\": "bundles/twilio-bundle/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "replace": {
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php71": "*",
    "symfony/polyfill-php70": "*",
    "symfony/polyfill-php56": "*"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "doctrine:migration:migrate -n": "symfony-cmd"
    },
    "gcp-build": [
      "composer install"
    ],
    "post-install-cmd": [
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false
    }
  }
}
