{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.gdpr.history.title'|trans }}{% endblock %}

{% import 'macros.html.twig' as macros %}

{% block body %}
    <div class="col-md-12 rc-section">
        <h3>{{ 'admin.gdpr.history.title'|trans }}</h3>

        <p class="text-muted">{{ 'admin.gdpr.history.help'|trans }}</p>

        {{ form_start(search) }}
        <div class="mb-3">
            {{ form_row(search.criteria) }}
        </div>
        <div class="mb-3">
            {{ form_row(search.hideTechnical) }}
        </div>
        <div class="text-right">
            {{ form_widget(search.submit, {'attr': {'class': 'btn btn-primary'}}) }}
        </div>
        {{ form_end(search) }}

        <div class="mt-4">
            {% if entries.nbResults == 0 %}
                <div class="alert alert-info">
                    {% if criteria %}
                        {{ 'admin.gdpr.history.no_results_for'|trans({'%criteria%': criteria}) }}
                    {% else %}
                        {{ 'admin.gdpr.history.empty'|trans }}
                    {% endif %}
                </div>
            {% else %}
                {% for entry in entries %}
                    {% include 'admin/gdpr/_card.html.twig' with {entry: entry} only %}
                {% endfor %}

                {{ macros.pager(entries) }}
            {% endif %}
        </div>

        <div class="text-center mt-4">
            <a href="{{ path('admin_gdpr_index') }}" class="btn btn-secondary">{{ 'base.button.back'|trans }}</a>
        </div>
    </div>
{% endblock %}
