{% if classification.problems or classification.reachable %}
    <h4>
        {{ 'audience.classification.title'|trans }}
    </h4>
{% endif %}

{% for key, list in classification.toArray %}
    {% if list %}
        <p>
            {{ ('audience.classification.' ~ (key|snake))|trans({'%nbr%': list|length})|raw }}
        </p>
    {% endif %}
{% endfor %}

{% if classification.problems %}

    <a href="#"
       class="btn btn-sm btn-secondary"
       id="open-problems">
        {{ 'audience.classification.problems'|trans }}
    </a>

{% endif %}

{% if classification.reachable or classification.excluded %}

    <a href="#"
       class="btn btn-sm btn-secondary"
       {% if classification.problems %}class="mt-1"{% endif %}
       id="open-audience">
        {{ 'audience.classification.audience'|trans }}
    </a>

    <script type="text/javascript">

        $(function () {
            $('.trigger-launch').prop('disabled', false);
        });

    </script>

{% else %}

    <script type="text/javascript">

        $(function () {
            $('.trigger-launch').prop('disabled', 'disabled');
        });

    </script>

{% endif %}

