{% if app.user|default(false) %}

    <div class="text-center auth-links">

        {% if display_user is not defined or display_user %}
            <div class="mb-3 font-weight-bold">
                {{ 'password_login.connect.who_am_i'|trans({'%username%': app.user.username}) }}
            </div>
        {% endif %}

        <div class="d-flex flex-column align-items-center">
            {% if is_granted('ROLE_ADMIN') %}
                {% if display_manage_users is not defined or display_manage_users %}
                    <a href="{{ path('password_login_admin_list') }}" class="btn btn-outline-info btn-block btn-sm mb-3">
                        {{ 'password_login.user_list.button'|trans }}
                    </a>
                {% endif %}
            {% endif %}

            <div class="d-flex justify-content-center w-100 flex-wrap">
                {% if display_profile is not defined or display_profile %}
                    <a href="{{ path('password_login_profile') }}" class="mx-2 mb-2">{{ 'password_login.profile.button'|trans }}</a>
                {% endif %}

                {% if display_logout is not defined or display_logout %}
                    <a href="{{ logout_url('main') }}" class="mx-2 mb-2 text-danger font-weight-bold">{{ 'password_login.logout.button'|trans }}</a>
                {% endif %}
            </div>
        </div>

    </div>

{% endif %}
