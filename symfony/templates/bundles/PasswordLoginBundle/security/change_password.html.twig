{% extends 'base.html.twig' %}

{% block title %}{{ 'password_login.change_password.title'|trans }}{% endblock %}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}

    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="auth-logo">
                <img src="{{ asset('build/images/redcall-full.png') }}" alt="RedCall Logo"/>
            </div>

            <h1 class="auth-title">{{ 'password_login.change_password.title'|trans }}</h1>

            {{ form_start(changePassword) }}
            {{ form_widget(changePassword) }}
            <div class="auth-actions">
                <button type="submit" class="btn btn-primary btn-block">
                    {{ 'password_login.change_password.submit'|trans|default('Change Password'|trans) }}
                </button>
                <button type="button" class="btn btn-link btn-block text-muted" onclick="window.location.href='{{ path('password_login_connect') }}'">
                    {{ 'base.button.back'|trans }}
                </button>
            </div>
            {{ form_end(changePassword) }}

            <div class="auth-locales text-center">
                {{ block('locales') }}
            </div>
        </div>
    </div>

{% endblock %}

