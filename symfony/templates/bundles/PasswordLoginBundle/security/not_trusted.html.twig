{% extends 'base.html.twig' %}

{% block title %}{{ 'password_login.not_trusted.title'|trans }}{% endblock %}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}

    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="auth-logo">
                <img src="{{ asset('build/images/redcall-full.png') }}" alt="RedCall Logo"/>
            </div>

            <h1 class="auth-title">{{ 'password_login.not_trusted.title'|trans }}</h1>

            <div class="alert alert-warning">
                {{ 'password_login.not_trusted.description'|trans }}
            </div>

            <div class="auth-actions">
                {{ include('@PasswordLogin/menu.html.twig', {
                    display_profile: false,
                    display_manage_users: false,
                }) }}
            </div>

            <div class="auth-locales text-center">
                {{ block('locales') }}
            </div>
        </div>
    </div>

{% endblock %}