{% extends 'base.html.twig' %}

{% block menu %}{% endblock %}

{% block body %}

    <div class="rc-section">

        <h3>{{ 'space.email.title'|trans }}</h3>

        <p>{{ 'space.email.details_1'|trans }}</p>

        {{ form(form) }}

        <p>{{ 'space.email.details_2'|trans({'%from%': from}) }}</p>
        <p>{{ 'space.email.details_3'|trans }} {{ 'space.email.details_4'|trans }} </p>

    </div>

    <div class="rc-back-link">
        <a href="{{ path('space_home', {sessionId: session.sessionId}) }}"
           class="btn btn-secondary">{{ 'base.button.back'|trans }}</a>
    </div>

{% endblock %}
