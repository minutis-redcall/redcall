{% extends 'base.html.twig' %}

{% macro field(label, value) %}
    <div class="mb-2">
        <div class="text-muted small">{{ label }}</div>
        <div>
            {% if value is empty %}
                <span class="text-muted">{{ 'manage_structures.pegass.field.none'|trans }}</span>
            {% else %}
                <strong>{{ value }}</strong>
            {% endif %}
        </div>
    </div>
{% endmacro %}

{% block body %}
    {% import _self as ui %}

    {% set volunteerIds = [] %}
    {% for group in content.volunteers|default([]) %}
        {% for volunteer in group.content|default([]) %}
            {% set volunteerIds = volunteerIds|merge([volunteer.id]) %}
        {% endfor %}
    {% endfor %}

    <div class="rc-section">

        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h1 class="mb-1">
                    {{ structure.name }}
                    <small class="text-muted">(ID: {{ content.structure.id|default(structure.externalId) }})</small>
                </h1>
                <div class="text-muted">{{ 'manage_structures.pegass.subtitle'|trans({'%date%': entity.updatedAt|date('d/m/Y H:i')}) }} UTC</div>
            </div>
            <a href="{{ path('management_structures_list') }}" class="btn btn-outline-secondary btn-sm">
                {{ 'manage_structures.pegass.back'|trans }}
            </a>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header"><strong>{{ 'manage_structures.pegass.section.identity'|trans }}</strong></div>
                    <div class="card-body">
                        {{ ui.field('manage_structures.pegass.field.id'|trans, content.structure.id|default('')) }}
                        {{ ui.field('manage_structures.pegass.field.label'|trans, content.structure.libelle|default('')) }}
                        {{ ui.field('manage_structures.pegass.field.short_label'|trans, content.structure.libelleCourt|default('')) }}
                        {{ ui.field('manage_structures.pegass.field.type'|trans, content.structure.typeStructure|default('')) }}
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header"><strong>{{ 'manage_structures.pegass.section.contact'|trans }}</strong></div>
                    <div class="card-body">
                        {{ ui.field('manage_structures.pegass.field.address'|trans, content.structure.adresse|default('')) }}
                        {{ ui.field('manage_structures.pegass.field.phone'|trans, content.structure.telephone|default('')) }}
                        {{ ui.field('manage_structures.pegass.field.email'|trans, content.structure.mail|default('')) }}
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header"><strong>{{ 'manage_structures.pegass.section.hierarchy'|trans }}</strong></div>
                    <div class="card-body">
                        <div class="mb-2">
                            <div class="text-muted small">{{ 'manage_structures.pegass.field.parent'|trans }}</div>
                            <div>
                                {% if content.structure.parent.id|default('') is not empty %}
                                    <span class="badge badge-light">{{ 'manage_structures.pegass.field.parent_id'|trans({'%id%': content.structure.parent.id}) }}</span>
                                {% else %}
                                    <span class="text-muted">{{ 'manage_structures.pegass.field.none'|trans }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header"><strong>{{ 'manage_structures.pegass.section.responsible'|trans }}</strong></div>
                    <div class="card-body">
                        {{ ui.field('manage_structures.pegass.field.responsible_id'|trans, content.responsible.responsableId|default('')) }}
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <strong>{{ 'manage_structures.pegass.section.activities'|trans }}</strong>
                <span class="badge badge-secondary">{{ content.structure.structureMenantActiviteList|default([])|length }}</span>
                <div class="text-muted small">{{ 'manage_structures.pegass.section.activities_help'|trans }}</div>
            </div>
            <div class="card-body">
                {% if content.structure.structureMenantActiviteList|default([])|length %}
                    <ul class="list-unstyled mb-0">
                        {% for activity in content.structure.structureMenantActiviteList %}
                            <li class="mb-1">
                                <strong>{{ activity.libelle }}</strong>
                                <span class="text-muted small">(#{{ activity.id }})</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <span class="text-muted">{{ 'manage_structures.pegass.field.none'|trans }}</span>
                {% endif %}
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header" style="cursor: pointer;" data-toggle="collapse" data-target="#pegass-volunteers" aria-expanded="false">
                <strong>{{ 'manage_structures.pegass.section.volunteers'|trans }}</strong>
                <span class="badge badge-secondary">{{ 'manage_structures.pegass.section.volunteers_count'|trans({'%count%': volunteerIds|length}) }}</span>
                <span class="text-muted small float-right">{{ 'manage_structures.pegass.raw_toggle'|trans }}</span>
                <div class="text-muted small">{{ 'manage_structures.pegass.section.volunteers_help'|trans }}</div>
            </div>
            <div id="pegass-volunteers" class="collapse">
                <div class="card-body">
                    {% if volunteerIds|length %}
                        {% for nivol in volunteerIds %}
                            <code class="mr-2">{{ nivol }}</code>
                        {% endfor %}
                    {% else %}
                        <span class="text-muted">{{ 'manage_structures.pegass.field.none'|trans }}</span>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header" style="cursor: pointer;" data-toggle="collapse" data-target="#pegass-raw" aria-expanded="false">
                <strong>{{ 'manage_structures.pegass.section.raw'|trans }}</strong>
                <span class="text-muted small float-right">{{ 'manage_structures.pegass.raw_toggle'|trans }}</span>
            </div>
            <div id="pegass-raw" class="collapse">
                <div class="card-body p-0">
                    <pre class="mb-0 p-3"><code>{{ pegass }}</code></pre>
                </div>
            </div>
        </div>

    </div>

{% endblock %}
