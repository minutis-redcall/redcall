{% extends 'base.html.twig' %}

{% macro contactRow(icon, label, value) %}
    <div class="d-flex align-items-center mb-2">
        <span class="mr-2" style="font-size: 1.2em;">{{ icon }}</span>
        <div>
            <div class="text-muted small">{{ label }}</div>
            <div><strong>{{ value }}</strong></div>
        </div>
    </div>
{% endmacro %}

{% macro formatDate(value) %}
    {%- if value is empty -%}
        <span class="text-muted">—</span>
    {%- else -%}
        {{ value|date('d/m/Y') }}
    {%- endif -%}
{% endmacro %}

{% block body %}
    {% import _self as ui %}

    <div class="rc-section">

        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h1 class="mb-1">
                    {{ volunteer.displayName }}
                    <small class="text-muted">({{ volunteer.externalId }})</small>
                </h1>
                <div class="text-muted">{{ 'manage_volunteers.pegass.subtitle'|trans({'%date%': entity.updatedAt|date('d/m/Y H:i')}) }} UTC</div>
            </div>
            <a href="{{ path('management_volunteers_list') }}" class="btn btn-outline-secondary btn-sm">
                {{ 'manage_volunteers.pegass.back'|trans }}
            </a>
        </div>

        <div class="mb-3">
            {% if content.user.actif %}
                <span class="badge badge-success">✓ {{ 'manage_volunteers.pegass.field.active'|trans }}</span>
            {% else %}
                <span class="badge badge-danger">🚫 {{ 'manage_volunteers.pegass.field.inactive'|trans }}</span>
            {% endif %}

            {% if content.user.mineur and content.user.mineur != '0' %}
                <span class="badge badge-warning">🐻 {{ 'manage_volunteers.pegass.field.minor'|trans }}</span>
            {% endif %}
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header"><strong>{{ 'manage_volunteers.pegass.section.identity'|trans }}</strong></div>
                    <div class="card-body">
                        <div class="mb-2">
                            <div class="text-muted small">{{ 'manage_volunteers.pegass.field.nivol'|trans }}</div>
                            <div><strong>{{ content.user.id }}</strong></div>
                        </div>
                        <div class="mb-2">
                            <div class="text-muted small">{{ 'manage_volunteers.pegass.field.structure'|trans }}</div>
                            <div><code>{{ content.user.structure.id }}</code></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header"><strong>{{ 'manage_volunteers.pegass.section.contact'|trans }}</strong></div>
                    <div class="card-body">
                        {% for contact in content.contact|default([]) %}
                            {% if contact.libelle is not empty %}
                                {% if contact.moyenComId == 'MAIL' %}
                                    {{ ui.contactRow('📧', 'manage_volunteers.pegass.field.email_personal'|trans, contact.libelle) }}
                                {% elseif contact.moyenComId == 'MAILTRAV' %}
                                    {{ ui.contactRow('📧', 'manage_volunteers.pegass.field.email_work'|trans, contact.libelle) }}
                                {% elseif contact.moyenComId == 'POR' %}
                                    {{ ui.contactRow('📱', 'manage_volunteers.pegass.field.phone'|trans, contact.libelle) }}
                                {% else %}
                                    {{ ui.contactRow('•', 'manage_volunteers.pegass.field.other_contact'|trans({'%type%': contact.moyenComId}), contact.libelle) }}
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <strong>{{ 'manage_volunteers.pegass.section.activities'|trans }}</strong>
                <span class="badge badge-secondary">{{ content.actions|default([])|length }}</span>
                <div class="text-muted small">{{ 'manage_volunteers.pegass.section.activities_help'|trans }}</div>
            </div>
            <div class="card-body">
                {% if content.actions|default([])|length %}
                    <ul class="list-unstyled mb-0">
                        {% for action in content.actions %}
                            <li class="mb-2">
                                <span class="badge badge-light">{{ 'manage_volunteers.pegass.field.structure_id'|trans({'%id%': action.structure.id}) }}</span>
                                <strong>{{ action.groupeAction.libelle }}</strong>
                                <span class="text-muted small">(#{{ action.groupeAction.id }})</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <span class="text-muted">{{ 'manage_volunteers.pegass.activity.none'|trans }}</span>
                {% endif %}
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <strong>{{ 'manage_volunteers.pegass.section.trainings'|trans }}</strong>
                <span class="badge badge-secondary">{{ content.trainings|default([])|length }}</span>
                <div class="text-muted small">{{ 'manage_volunteers.pegass.section.trainings_help'|trans }}</div>
            </div>
            <div class="card-body p-0">
                {% if content.trainings|default([])|length %}
                    <table class="table table-striped mb-0">
                        <thead>
                        <tr>
                            <th>{{ 'manage_volunteers.pegass.training.code'|trans }}</th>
                            <th>{{ 'manage_volunteers.pegass.training.label'|trans }}</th>
                            <th>{{ 'manage_volunteers.pegass.training.obtained'|trans }}</th>
                            <th>{{ 'manage_volunteers.pegass.training.renewed_until'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for training in content.trainings %}
                            <tr>
                                <td><code>{{ training.formation.code }}</code></td>
                                <td>{{ training.formation.libelle }}</td>
                                <td>{{ ui.formatDate(training.dateObtention) }}</td>
                                <td>{{ ui.formatDate(training.dateRecyclage) }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="card-body"><span class="text-muted">{{ 'manage_volunteers.pegass.training.none'|trans }}</span></div>
                {% endif %}
            </div>
        </div>

        {% if content.skills|default([])|length %}
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <strong>{{ 'manage_volunteers.pegass.section.skills'|trans }}</strong>
                    <span class="badge badge-secondary">{{ content.skills|length }}</span>
                </div>
                <div class="card-body">
                    {% for skill in content.skills %}
                        <span class="badge badge-info mr-1">{{ skill.libelle }} <small>(#{{ skill.id }})</small></span>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {% if content.nominations|default([])|length %}
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <strong>{{ 'manage_volunteers.pegass.section.nominations'|trans }}</strong>
                    <span class="badge badge-secondary">{{ content.nominations|length }}</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <thead>
                        <tr>
                            <th>{{ 'manage_volunteers.pegass.nomination.code'|trans }}</th>
                            <th>{{ 'manage_volunteers.pegass.nomination.label'|trans }}</th>
                            <th>{{ 'manage_volunteers.pegass.nomination.structure'|trans }}</th>
                            <th>{{ 'manage_volunteers.pegass.nomination.date'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for nomination in content.nominations %}
                            <tr>
                                <td><code>{{ nomination.libelleCourt }}</code></td>
                                <td>{{ nomination.libelleLong }}</td>
                                <td><span class="badge badge-light">{{ nomination.structure.id }}</span></td>
                                <td>{{ ui.formatDate(nomination.dateValidation) }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

        <div class="card shadow-sm mb-4">
            <div class="card-header" style="cursor: pointer;" data-toggle="collapse" data-target="#pegass-raw" aria-expanded="false">
                <strong>{{ 'manage_volunteers.pegass.section.raw'|trans }}</strong>
                <span class="text-muted small float-right">{{ 'manage_volunteers.pegass.raw_toggle'|trans }}</span>
            </div>
            <div id="pegass-raw" class="collapse">
                <div class="card-body p-0">
                    <pre class="mb-0 p-3"><code>{{ pegass }}</code></pre>
                </div>
            </div>
        </div>

    </div>

{% endblock %}
