{% extends 'base.html.twig' %}

{% block stylesheets %}
    <style>
        :root {
            --tree-rule: #e8e8e8;
            --tree-rule-strong: #cfcfcf;
            --tree-ink: #1a1a1a;
            --tree-mute: #7a7a7a;
            --tree-faint: #b5b5b5;
            --tree-paper: #ffffff;
            --tree-paper-tint: #fbfbfb;
            --tree-row-hover: #fafafa;
            --tree-accent: var(--rc-red);
            --tree-accent-soft: rgba(227, 6, 19, 0.08);
            --tree-accent-faint: rgba(227, 6, 19, 0.04);
        }

        .resources-hub {
            padding: 2rem clamp(1rem, 3vw, 2.5rem) 2.5rem;
        }

        /* ───────── Quick-link rail ───────── */
        .resources-rail {
            display: flex;
            flex-wrap: wrap;
            gap: 0;
            border-top: 1px solid var(--tree-rule);
            border-bottom: 1px solid var(--tree-rule);
            margin: 0 0 2.5rem;
        }
        .resources-rail a {
            flex: 1 1 auto;
            min-width: 180px;
            padding: 0.875rem 1rem;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--tree-ink);
            text-decoration: none;
            border-right: 1px solid var(--tree-rule);
            transition: background-color 0.15s ease, color 0.15s ease;
            display: flex;
            align-items: center;
            gap: 0.55rem;
        }
        .resources-rail a:last-child { border-right: none; }
        .resources-rail a:hover {
            background: var(--tree-accent-faint);
            color: var(--tree-accent);
        }
        .resources-rail a .rail-glyph {
            font-size: 1rem;
            line-height: 1;
        }

        /* ───────── Section heading ───────── */
        .tree-heading {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.75rem 2rem;
            margin-bottom: 1.75rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid var(--tree-rule);
        }
        .tree-heading .heading-title {
            font-size: 1.05rem;
            font-weight: 600;
            letter-spacing: -0.005em;
            color: var(--tree-ink);
            margin: 0;
        }
        .tree-heading .heading-title::after {
            display: none;
        }
        .tree-heading .heading-stats {
            font-size: 0.75rem;
            color: var(--tree-mute);
            letter-spacing: 0.02em;
            font-variant-numeric: tabular-nums;
        }
        .tree-heading .heading-stats strong {
            color: var(--tree-ink);
            font-weight: 600;
            font-feature-settings: "tnum";
        }
        .tree-heading .heading-stats .sep {
            margin: 0 0.6rem;
            color: var(--tree-faint);
        }

        /* ───────── Tree ───────── */
        .structure-tree {
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .structure-tree ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .tree-node {
            position: relative;
        }

        /* Child branches use rule + indentation */
        .tree-node .tree-children {
            position: relative;
            margin-left: 1.65rem;
            padding-left: 1.1rem;
            border-left: 1px solid var(--tree-rule);
        }
        .tree-node .tree-children > .tree-node::before {
            content: '';
            position: absolute;
            top: 1.45rem;
            left: -1.1rem;
            width: 0.95rem;
            height: 1px;
            background: var(--tree-rule);
        }

        /* ───────── Tree item (the row) ───────── */
        .tree-item {
            background: var(--tree-paper);
            border: 1px solid var(--tree-rule);
            border-radius: 6px;
            margin-top: 0.5rem;
            overflow: hidden;
            transition: border-color 0.18s ease, box-shadow 0.18s ease;
        }
        .tree-item[open] {
            border-color: var(--tree-rule-strong);
            box-shadow: 0 1px 0 rgba(0,0,0,0.02), 0 6px 22px -16px rgba(0,0,0,0.18);
        }
        .tree-node[data-depth="0"] > .tree-item {
            background: var(--tree-paper);
            border-color: var(--tree-rule-strong);
        }

        /* ───────── Summary row ───────── */
        .tree-summary {
            list-style: none;
            cursor: pointer;
            padding: 0.85rem 1.1rem 0.85rem 0.9rem;
            display: grid;
            grid-template-columns: auto 1fr auto;
            align-items: center;
            gap: 0.85rem;
            transition: background-color 0.15s ease;
        }
        .tree-summary::-webkit-details-marker { display: none; }
        .tree-summary::marker { content: ''; }
        .tree-summary:hover {
            background: var(--tree-row-hover);
        }
        .tree-item[open] > .tree-summary {
            background: var(--tree-paper-tint);
            border-bottom: 1px solid var(--tree-rule);
        }

        .tree-chevron {
            width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--tree-faint);
            transition: transform 0.18s ease, color 0.18s ease;
            font-size: 0.7rem;
        }
        .tree-item[open] > .tree-summary .tree-chevron {
            transform: rotate(90deg);
            color: var(--tree-accent);
        }
        .tree-summary:hover .tree-chevron {
            color: var(--tree-ink);
        }

        .tree-identity {
            min-width: 0;
            display: flex;
            align-items: center;
            gap: 0.65rem;
            flex-wrap: wrap;
        }
        .tree-level {
            font-size: 0.62rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            color: var(--tree-mute);
            text-transform: uppercase;
            border: 1px solid var(--tree-rule-strong);
            border-radius: 2px;
            padding: 1px 5px;
            line-height: 1.4;
            font-variant-numeric: tabular-nums;
            font-feature-settings: "tnum";
            background: #fff;
        }
        .tree-node[data-depth="0"] > .tree-item > .tree-summary .tree-level {
            color: var(--tree-accent);
            border-color: var(--tree-accent);
        }
        .tree-name {
            font-size: 0.92rem;
            font-weight: 600;
            color: var(--tree-ink);
            letter-spacing: -0.005em;
            line-height: 1.25;
        }
        .tree-node[data-depth="0"] > .tree-item > .tree-summary .tree-name {
            font-size: 1rem;
        }
        .tree-shortcut {
            font-size: 0.7rem;
            color: var(--tree-faint);
            font-weight: 500;
            letter-spacing: 0.02em;
        }

        .tree-counter {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.32rem 0.7rem;
            background: #f4f4f4;
            border: 1px solid var(--tree-rule);
            border-radius: 999px;
            font-size: 0.72rem;
            color: var(--tree-mute);
            white-space: nowrap;
            font-variant-numeric: tabular-nums;
            font-feature-settings: "tnum";
        }
        .tree-counter .count-num {
            color: var(--tree-ink);
            font-weight: 700;
            font-size: 0.78rem;
        }
        .tree-counter.is-empty {
            background: transparent;
            color: var(--tree-faint);
            border-style: dashed;
        }
        .tree-counter.is-empty .count-num { color: var(--tree-faint); }
        .tree-summary:hover .tree-counter:not(.is-empty) {
            border-color: var(--tree-accent);
            color: var(--tree-accent);
            background: var(--tree-accent-faint);
        }
        .tree-summary:hover .tree-counter:not(.is-empty) .count-num {
            color: var(--tree-accent);
        }

        /* ───────── Reveal panel ───────── */
        .tree-body {
            padding: 0.85rem 1.1rem 1rem 2.7rem;
            background: var(--tree-paper-tint);
            animation: panelFadeIn 0.22s ease;
        }
        @keyframes panelFadeIn {
            from { opacity: 0; transform: translateY(-3px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .peer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 0.5rem;
        }
        .peer-card {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            padding: 0.55rem 0.7rem;
            border: 1px solid var(--tree-rule);
            border-radius: 4px;
            background: #fff;
            transition: border-color 0.15s ease, transform 0.15s ease;
        }
        .peer-card:hover {
            border-color: var(--tree-accent);
            transform: translateY(-1px);
        }
        .peer-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--tree-paper-tint);
            border: 1px solid var(--tree-rule-strong);
            color: var(--tree-ink);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            flex: 0 0 auto;
        }
        .peer-avatar.is-warn {
            background: #fff7e6;
            border-color: #f3c969;
            color: #8a5b00;
        }
        .peer-meta {
            min-width: 0;
            line-height: 1.25;
        }
        .peer-name {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--tree-ink);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .peer-name.is-warn { color: var(--tree-accent); }
        .peer-id {
            font-size: 0.7rem;
            color: var(--tree-mute);
            font-variant-numeric: tabular-nums;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .peer-warn-line {
            font-size: 0.7rem;
            color: var(--tree-mute);
            margin-top: 1px;
        }

        .peer-empty {
            font-size: 0.78rem;
            color: var(--tree-mute);
            font-style: italic;
            padding: 0.4rem 0.25rem;
            border-left: 2px solid var(--tree-rule-strong);
            padding-left: 0.8rem;
        }

        /* ───────── Footer ───────── */
        .resources-footnote {
            margin-top: 2.5rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--tree-rule);
            font-size: 0.74rem;
            color: var(--tree-mute);
            text-align: center;
            letter-spacing: 0.01em;
        }
        .resources-back {
            text-align: center;
            margin-top: 1.5rem;
        }
        .resources-back a {
            font-size: 0.78rem;
            color: var(--tree-mute);
            letter-spacing: 0.04em;
            text-transform: uppercase;
            font-weight: 600;
            text-decoration: none;
        }
        .resources-back a:hover { color: var(--tree-accent); }

        /* ───────── Responsive tweaks ───────── */
        @media (max-width: 575px) {
            .tree-summary {
                grid-template-columns: auto 1fr;
                row-gap: 0.45rem;
            }
            .tree-counter {
                grid-column: 1 / -1;
                justify-self: start;
                margin-left: 1.5rem;
            }
            .tree-node .tree-children {
                margin-left: 0.85rem;
                padding-left: 0.85rem;
            }
            .tree-node .tree-children > .tree-node::before {
                left: -0.85rem;
                width: 0.7rem;
            }
            .tree-body {
                padding-left: 1.1rem;
            }
        }
    </style>
{% endblock %}

{% macro tree_node(structure, depth, childrenByParent, currentUserId) %}
    {% import _self as tree %}
    {% set children = childrenByParent[structure.id]|default([]) %}
    {% set peers = structure.users|filter(u => u.id != currentUserId) %}
    {% set peerCount = peers|length %}

    <li class="tree-node" data-depth="{{ depth }}">
        <details class="tree-item">
            <summary class="tree-summary">
                <span class="tree-chevron" aria-hidden="true">▸</span>
                <span class="tree-identity">
                    <span class="tree-level" title="{{ 'management.tree.level_title'|trans({'%depth%': depth + 1}) }}">N{{ depth + 1 }}</span>
                    <span class="tree-name">{{ structure.name }}</span>
                    {% if structure.shortcut %}
                        <span class="tree-shortcut">· {{ structure.shortcut }}</span>
                    {% endif %}
                </span>
                <span class="tree-counter {% if peerCount == 0 %}is-empty{% endif %}">
                    <span class="count-num">{{ peerCount }}</span>
                    <span>{{ 'management.tree.peers'|trans({'%count%': peerCount}) }}</span>
                </span>
            </summary>
            <div class="tree-body">
                {% if peerCount == 0 %}
                    <div class="peer-empty">{{ 'management.no_other_users'|trans }}</div>
                {% else %}
                    <div class="peer-grid">
                        {% for user in peers %}
                            <div class="peer-card">
                                {% if user.firstName or user.lastName %}
                                    <span class="peer-avatar">
                                        {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                    </span>
                                    <div class="peer-meta">
                                        <div class="peer-name">
                                            {{ user.firstName }} {{ user.lastName }}
                                        </div>
                                        {% if user.externalId %}
                                            <div class="peer-id">{{ 'management.external_id_label'|trans({'%external_id%': user.externalId}) }}</div>
                                        {% endif %}
                                    </div>
                                {% else %}
                                    <span class="peer-avatar is-warn">!</span>
                                    <div class="peer-meta">
                                        <div class="peer-name is-warn">{{ user.username }}</div>
                                        <div class="peer-warn-line">{{ 'management.missing_volunteer'|trans }}</div>
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </details>

        {% if children|length > 0 %}
            <ul class="tree-children">
                {% for child in children %}
                    {{ tree.tree_node(child, depth + 1, childrenByParent, currentUserId) }}
                {% endfor %}
            </ul>
        {% endif %}
    </li>
{% endmacro %}

{% block body %}
    {% import _self as tree %}

    <div class="rc-section resources-hub">
        <h1>{{ 'management.home.link'|trans }}</h1>

        <nav class="resources-rail" aria-label="{{ 'management.home.link'|trans }}">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_badge_index') }}">
                    <span class="rail-glyph">🎖️</span>{{ 'admin.badge.title'|trans }}
                </a>
            {% endif %}
            <a href="{{ path('management_structures_list') }}">
                <span class="rail-glyph">🏢</span>{{ 'manage_structures.title'|trans }}
            </a>
            <a href="{{ path('management_volunteers_list') }}">
                <span class="rail-glyph">👥</span>{{ 'manage_volunteers.title'|trans }}
            </a>
            <a href="{{ path('management_structures_volunteer_lists_home') }}">
                <span class="rail-glyph">📋</span>{{ 'manage_structures.volunteer_list.manage'|trans }}
            </a>
        </nav>

        <header class="tree-heading">
            <h2 class="heading-title">{{ 'management.current_structures'|trans }}</h2>
            <div class="heading-stats">
                <strong>{{ structuresCount }}</strong>
                {{ 'management.tree.structures'|trans({'%count%': structuresCount}) }}
                <span class="sep">·</span>
                <strong>{{ peersCount }}</strong>
                {{ 'management.tree.peers_total'|trans({'%count%': peersCount}) }}
            </div>
        </header>

        <ul class="structure-tree">
            {% for root in roots %}
                {{ tree.tree_node(root, 0, childrenByParent, app.user.id) }}
            {% endfor %}
        </ul>

        <p class="resources-footnote">
            📧 {{ 'management.support_email'|trans({'%email%': email}) }}
        </p>

        <div class="resources-back">
            <a href="{{ path('home') }}">← {{ 'base.button.back'|trans }}</a>
        </div>
    </div>
{% endblock %}
